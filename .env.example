# ─── Base de datos ────────────────────────────────────────────────────────────
# Conexión runtime de Prisma — usar URL de connection pooler en producción (puerto 6543)
DATABASE_URL=

# Conexión directa para Prisma CLI y schema sync (puerto 5432, no pasar por pooler)
DIRECT_URL=

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Secreto para firmar JWT. Generar con: openssl rand -base64 32
AUTH_SECRET=

# Credenciales Google OAuth — crear en https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# URL pública del entorno. En producción usar la URL real (ej: https://tu-app.vercel.app)
# NO usar http://localhost:3000 en producción
AUTH_URL=

# ─── CTA de renovación (opcionales) ──────────────────────────────────────────
# Si no están definidas, el botón "Contactar para renovar" no aparece en alertas de membresía
# NEXT_PUBLIC_GYM_WHATSAPP_NUMBER=521XXXXXXXXXX
# NEXT_PUBLIC_GYM_CONTACT_EMAIL=

# ─── Notas ────────────────────────────────────────────────────────────────────
# Copiar este archivo como .env.local y completar los valores reales.
# NUNCA commitear .env.local — está en .gitignore.

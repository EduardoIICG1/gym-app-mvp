generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COACH
  MEMBER
  KINESIOLOGIST
}

enum ServiceType {
  GROUP
  PERSONAL_TRAINING
  KINESIOLOGY
  OTHER
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  INVITED
  CONFIRMED
  CANCELLED
  WAITLISTED
  ATTENDED
  ABSENT
}

enum MembershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  WAIVED
}

enum GrantType {
  PURCHASED
  RENEWAL
  REACTIVATION
  GIFT
  COMPENSATION
  TRIAL
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum AnnouncementType {
  INFO
  ALERT
  EVENT
  MAINTENANCE
}

enum AnnouncementStatus {
  PUBLISHED
  ARCHIVED
}

enum HealthSessionStatus {
  OPEN
  CLOSED
}

enum RestrictionSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AppearanceMode {
  LIGHT
  DARK
  SYSTEM
}

// ─── Business Models ─────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(MEMBER)
  phone     String?
  rut       String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coachSessions         Session[]           @relation("CoachSessions")
  coachRelations        MemberCoach[]       @relation("CoachRelations")
  memberRelations       MemberCoach[]       @relation("MemberRelations")
  bookings              Booking[]
  memberships           Membership[]
  defaultPrograms       Program[]           @relation("DefaultCoach")
  announcements         Announcement[]      @relation("AuthorAnnouncements")
  grantedMemberships    Membership[]        @relation("MembershipGrantedBy")
  memberInvitations     BookingInvitation[] @relation("MemberInvitations")
  sentInvitations       BookingInvitation[] @relation("SentInvitations")

  // Health module relations
  healthRecord           HealthRecord?        @relation("PatientRecord")
  createdHealthRecords   HealthRecord[]       @relation("RecordCreatedBy")
  kinesiologistSessions  HealthSession[]      @relation("KinesiologistSessions")
  patientHealthSessions  HealthSession[]      @relation("PatientHealthSessions")
  patientRestrictions    HealthRestriction[]  @relation("PatientRestrictions")
  createdRestrictions    HealthRestriction[]  @relation("RestrictionCreatedBy")

  // Branding relations
  updatedGymSettings GymSettings[] @relation("GymSettingsUpdatedBy")
}

// Many-to-many: Member ↔ Coach with service type
model MemberCoach {
  id          String      @id @default(cuid())
  memberId    String
  coachId     String
  serviceType ServiceType
  isActive    Boolean     @default(true)
  startDate   DateTime    @default(now())
  endDate     DateTime?

  member User @relation("MemberRelations", fields: [memberId], references: [id])
  coach  User @relation("CoachRelations", fields: [coachId], references: [id])

  @@unique([memberId, coachId, serviceType])
}

// Class/service definition (recurring template for group classes)
model Program {
  id             String      @id @default(cuid())
  name           String
  description    String?
  serviceType    ServiceType
  durationMin    Int         @default(60)
  maxCapacity    Int?
  isActive       Boolean     @default(true)
  // Recurring schedule fields (group classes; null = non-recurring)
  dayOfWeek      Int? // 0=Mon … 5=Sat
  startTime      String? // "06:00" HH:mm
  defaultCoachId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  defaultCoach User?     @relation("DefaultCoach", fields: [defaultCoachId], references: [id])
  sessions     Session[]
}

// Concrete session instance — real dated occurrence of a Program
model Session {
  id        String        @id @default(cuid())
  programId String
  coachId   String
  startsAt  DateTime
  endsAt    DateTime
  location  String?
  notes     String?
  status    SessionStatus @default(SCHEDULED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  program       Program             @relation(fields: [programId], references: [id])
  coach         User                @relation("CoachSessions", fields: [coachId], references: [id])
  bookings      Booking[]
  invitations   BookingInvitation[]
  healthSession HealthSession?      @relation("HealthSessionLink")

  @@unique([programId, startsAt])
  @@index([coachId])
}

// Member ↔ Session — Booking always references a real Session
model Booking {
  id        String        @id @default(cuid())
  sessionId String
  memberId  String
  status    BookingStatus @default(INVITED)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  session    Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member     User               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  invitation BookingInvitation?

  @@unique([sessionId, memberId])
  @@index([memberId])
  @@index([sessionId])
}

// Coach/Admin convocatoria — PENDING does not consume capacity.
// Booking is created only when status transitions to ACCEPTED.
model BookingInvitation {
  id          String           @id @default(cuid())
  sessionId   String
  memberId    String
  invitedById String
  status      InvitationStatus @default(PENDING)
  bookingId   String?          @unique
  message     String?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member    User     @relation("MemberInvitations",  fields: [memberId],    references: [id])
  invitedBy User     @relation("SentInvitations",    fields: [invitedById], references: [id])
  booking   Booking? @relation(fields: [bookingId],  references: [id])

  @@unique([sessionId, memberId])
  @@index([memberId])
  @@index([sessionId])
  @@index([status])
}

// Member subscription plan
model Membership {
  id            String           @id @default(cuid())
  memberId      String
  planName      String
  serviceType   ServiceType
  totalSessions Int? // null = unlimited / monthly flat
  usedSessions  Int              @default(0)
  startDate     DateTime
  endDate       DateTime?
  status        MembershipStatus @default(ACTIVE)
  amount        Int              @default(0)
  paymentStatus PaymentStatus    @default(PAID)
  grantType     GrantType        @default(PURCHASED)
  grantedById   String?
  grantReason   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt

  member    User  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  grantedBy User? @relation("MembershipGrantedBy", fields: [grantedById], references: [id])

  @@index([memberId])
  @@index([status])
}

model Announcement {
  id          String             @id @default(cuid())
  title       String?
  content     String
  type        AnnouncementType   @default(INFO)
  authorId    String
  isPinned    Boolean            @default(false)
  publishedAt DateTime           @default(now())
  expiresAt   DateTime?
  linkUrl       String?
  linkLabel     String?
  coverImageKey String?
  status        AnnouncementStatus @default(PUBLISHED)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  author User @relation("AuthorAnnouncements", fields: [authorId], references: [id])

  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
}

// ─── Health Module ────────────────────────────────────────────────────────────

// Master patient clinical file — one per kinesiology patient
model HealthRecord {
  id          String @id @default(cuid())
  patientId   String @unique
  createdById String

  // Anamnesis
  birthDate         DateTime?
  biologicalSex     String?
  occupation        String?
  reasonForConsult  String?
  medicalBackground String?
  surgeries         String?
  currentMedication String?
  allergies         String?
  painLevel         Int?

  // Clinical assessment
  initialAssessment String?
  diagnosis         String?
  treatmentGoals    String?
  internalNotes     String? // KINESIOLOGIST and ADMIN only

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient      User               @relation("PatientRecord",   fields: [patientId],   references: [id])
  createdBy    User               @relation("RecordCreatedBy", fields: [createdById], references: [id])
  sessions     HealthSession[]
  restrictions HealthRestriction[]

  @@index([patientId])
  @@index([createdById])
}

// Clinical notes per appointment — SOAP format with auto-save
model HealthSession {
  id              String              @id @default(cuid())
  healthRecordId  String
  sessionId       String?  @unique    // optional 1-to-1 link to existing scheduling Session
  kinesiologistId String
  patientId       String              // denormalized for query performance

  sessionDate     DateTime

  // SOAP notes
  subjective      String?
  objective       String?
  assessment      String?
  plan            String?

  exercises       String?
  observations    String?
  privateNotes    String? // KINESIOLOGIST and ADMIN only
  patientNotes    String? // visible to the patient

  status          HealthSessionStatus @default(OPEN)
  // Prepared for Phase 2 re-open support:
  // closedAt     DateTime?
  // reopenedAt   DateTime?
  // reopenedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  healthRecord  HealthRecord @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  linkedSession Session?     @relation("HealthSessionLink",     fields: [sessionId],      references: [id])
  kinesiologist User         @relation("KinesiologistSessions", fields: [kinesiologistId], references: [id])
  patient       User         @relation("PatientHealthSessions", fields: [patientId],       references: [id])

  @@index([healthRecordId])
  @@index([kinesiologistId])
  @@index([patientId])
  @@index([sessionDate])
}

// Operational restrictions/considerations — visible to all gym staff, not just kinesiologists.
// healthRecordId is optional: kine-linked restrictions reference a HealthRecord,
// coach-created operational notes do not (no clinical context needed).
model HealthRestriction {
  id             String              @id @default(cuid())
  healthRecordId String?             // null when created by COACH without a health record
  patientId      String
  createdById    String
  sourceRole     Role?               // tracks which role created this entry

  label          String
  severity       RestrictionSeverity @default(INFO)
  isActive       Boolean             @default(true)
  startDate      DateTime            @default(now())
  endDate        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  healthRecord HealthRecord? @relation(fields: [healthRecordId], references: [id], onDelete: Cascade)
  patient      User          @relation("PatientRestrictions",  fields: [patientId],   references: [id])
  createdBy    User          @relation("RestrictionCreatedBy", fields: [createdById], references: [id])

  @@index([healthRecordId])
  @@index([patientId])
  @@index([isActive])
}

// ─── Branding / Tenant Configuration ──────────────────────────────────────────

// Persisted visual identity configuration for the gym.
//
// MVP note (single tenant): there is currently no Gym/Tenant/Organization entity.
// This table holds a single row (id = "primary") representing Primary Performance.
// All reads/writes target that fixed row.
//
// Future multi-tenant migration path:
//   1. Introduce a `Gym`/`Tenant` model.
//   2. Add `gymId String @unique` to this model, FK'd to `Gym.id`.
//   3. Backfill the existing "primary" row with the Primary Performance gymId.
//   4. Drop the fixed-id convention; resolve settings by the authenticated user's gymId.
// No application code outside `src/lib/branding.ts` should assume a single row —
// all reads go through `getGymSettings()` / `getBranding()`.
model GymSettings {
  id              String         @id @default("primary")
  gymName         String         @default("Primary Performance")
  logoUrl         String?
  logoStoragePath String?
  primaryColor    String         @default("#4fc3f7")
  accentColor     String         @default("#22c55e")
  appearanceMode  AppearanceMode @default(DARK)
  updatedById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  updatedBy User? @relation("GymSettingsUpdatedBy", fields: [updatedById], references: [id])
}
